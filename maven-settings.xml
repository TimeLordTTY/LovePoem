<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 https://maven.apache.org/xsd/settings-1.0.0.xsd">

  <!--
    项目专用 Maven 仓库配置
    - 不修改全局 ~/.m2/settings.xml
    - 通过 -s maven-settings.xml 只在当前项目使用
    - 使用 HTTPS 的中央仓库 / 阿里云镜像，避免 maven-default-http-blocker 拦截
  -->

  <mirrors>
    <!-- 阿里云公共仓库镜像（走 HTTPS，适合国内网络） -->
    <mirror>
      <id>aliyunmaven</id>
      <mirrorOf>central</mirrorOf>
      <name>Aliyun Maven</name>
      <url>https://maven.aliyun.com/repository/public</url>
    </mirror>
  </mirrors>

  <profiles>
    <profile>
      <id>love-poem-repos</id>
      <repositories>
        <!-- 显式声明中央仓库（HTTPS） -->
        <repository>
          <id>central</id>
          <url>https://repo1.maven.org/maven2/</url>
          <releases>
            <enabled>true</enabled>
          </releases>
          <snapshots>
            <enabled>false</enabled>
          </snapshots>
        </repository>
      </repositories>
    </profile>
  </profiles>

  <activeProfiles>
    <activeProfile>love-poem-repos</activeProfile>
  </activeProfiles>

</settings>

